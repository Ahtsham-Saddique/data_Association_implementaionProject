
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login page</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>

<div class="w-full min-h-screen bg-zinc-900 flex items-center justify-center px-4">

    <div class="w-full max-w-md bg-zinc-800 rounded-3xl shadow-2xl p-8">

        <div class="text-center mb-6">
          <h1 class="text-3xl font-semibold">Login</h1>
          <p class="text-zinc-400 mt-2">Welcome back</p>
        </div>

        <form action="/login" method="post" class="space-y-4">
          <input
            type="email"
            placeholder="Email"
            name="email"
            class="w-full px-4 py-3 rounded-xl bg-zinc-900/30 text-white placeholder-zinc-500 outline-none border border-zinc-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
          >

          <input
            type="password"
            placeholder="Password"
            name="password"
            class="w-full px-4 py-3 rounded-xl bg-zinc-900/30 text-white placeholder-zinc-500 outline-none border border-zinc-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
          >

          <input
            type="submit"
            value="Login"
            class="w-full py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold cursor-pointer transition-all duration-200 shadow-sm shadow-blue-600/30"
          >
        </form>
      </div>
  </div>
</body>
</html>
