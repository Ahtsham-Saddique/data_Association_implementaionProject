```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create_Account</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>

<div class="w-full min-h-screen bg-zinc-900 flex items-center justify-center px-4">

    <div class="w-full max-w-md bg-zinc-800 rounded-3xl shadow-2xl p-8">

        <h1 class="text-3xl font-bold text-white text-center mb-2">
            Create Account
        </h1>

        

        <form action="/register" method="post" class="space-y-4">

            <input
                type="text"
                placeholder="Name"
                name="name"
                class="w-full px-4 py-3 rounded-xl bg-zinc-700 text-white placeholder-zinc-400 outline-none border border-zinc-600 focus:border-blue-500"
            >

            <input
                type="text"
                placeholder="Username"
                name="username"
                class="w-full px-4 py-3 rounded-xl bg-zinc-700 text-white placeholder-zinc-400 outline-none border border-zinc-600 focus:border-blue-500"
            >

            <input
                type="password"
                placeholder="Password"
                name="password"
                class="w-full px-4 py-3 rounded-xl bg-zinc-700 text-white placeholder-zinc-400 outline-none border border-zinc-600 focus:border-blue-500"
            >

            <input
                type="email"
                placeholder="Email"
                name="email"
                class="w-full px-4 py-3 rounded-xl bg-zinc-700 text-white placeholder-zinc-400 outline-none border border-zinc-600 focus:border-blue-500"
            >

            <input
                type="number"
                placeholder="Age"
                name="age"
                class="w-full px-4 py-3 rounded-xl bg-zinc-700 text-white placeholder-zinc-400 outline-none border border-zinc-600 focus:border-blue-500"
            >

            <input
                type="submit"
                value="Create Account"
                class="w-full py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold cursor-pointer transition-all duration-200"
            >

        </form>

    </div>

</div>

</body>
</html>