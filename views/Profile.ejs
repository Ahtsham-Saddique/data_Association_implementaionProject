<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-900 text-white min-h-screen p-10">

    <!-- Top Bar -->
    <div class="flex justify-end mb-6">
        <a href="/logout" class="bg-red-500 px-4 py-2 rounded-md text-sm">
            Logout
        </a>
    </div>

    <!-- Greeting -->
    <h1 class="text-3xl mb-2">
        <span class="font-light">Hello</span>, <%= user.name %>
    </h1>

    <p class="text-zinc-400 mb-6">
        Create and manage your posts
    </p>

    <!-- Create Post Form -->
    <form action="/post" method="post" class="mb-10">
        
        <textarea 
            name="content"
            placeholder="What's on your mind?"
            class="w-full p-3 rounded-md bg-zinc-800 text-white outline-none mb-3"
            rows="4"
        ></textarea>

        <button 
            type="submit"
            class="bg-blue-500 px-5 py-2 rounded-md text-sm"
        >
            Create Post
        </button>

    </form>

   

</body>
</html>