<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profile</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-900 text-white min-h-screen">
  <div class="max-w-3xl mx-auto px-5 py-8">
    <!-- Top Right Logout -->
    <div class="flex justify-end mb-8">
      <a href="/logout" class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded-lg text-sm font-medium">
        Logout
      </a>
    </div>

    <!-- Profile Header -->
    <div class="flex items-center gap-4 mb-8">
      <a
        href="/profile/upload"
        class="relative inline-block rounded-full overflow-hidden w-20 h-20 ring-2 ring-zinc-700 hover:ring-blue-500 transition"
        title="Update profile picture"
      >
        <img class="w-full h-full object-cover" src="/images/uploads/<%= user.profilepic %>" alt="Profile" />
        <div class="absolute inset-0 bg-black/0 hover:bg-black/30 transition flex items-center justify-center">
          <span class="opacity-0 hover:opacity-100 text-xs font-semibold">Update</span>
        </div>
      </a>

      <div>
        <h1 class="text-3xl font-semibold">
          <span class="font-light text-zinc-300">Hello</span>, <%= user.name %>
        </h1>
        <p class="text-zinc-400 mt-1">Create and manage your posts</p>
        <div class="mt-3">
          <a
            href="/profile/upload"
            class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm font-medium"
          >
            Update Profile Picture
          </a>
        </div>
        <p class="text-zinc-500 text-sm mt-2">Click your profile photo to update.</p>
      </div>
    </div>

    <!-- Create Post Form -->
    <div class="bg-zinc-800 rounded-2xl p-5 mb-6">
      <form action="/post" method="post" class="space-y-4">
        <textarea
          name="content"
          placeholder="What's on your mind?"
          class="w-full p-3 rounded-xl bg-zinc-900/40 text-white outline-none border border-zinc-700 focus:border-blue-500"
          rows="4"
        ></textarea>
        <button
          type="submit"
          class="bg-blue-600 hover:bg-blue-700 px-5 py-2 rounded-xl text-sm font-semibold"
        >
          Create Post
        </button>
      </form>
    </div>

    <!-- Posts Section -->
    <div class="mt-6">
      <h2 class="text-xl font-semibold mb-4">Your Posts</h2>

      <% if(user.posts.length > 0) { %>
        <% user.posts.slice().reverse().forEach(post => { %>
          <div class="bg-zinc-800 rounded-2xl p-5 mb-4">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="text-white mb-3 break-words"> <%= post.content %> </p>
                <p class="text-zinc-400 text-sm"> <%= post.date.toDateString() %> </p>
              </div>
            </div>

            <div class="flex flex-wrap gap-3 mt-5">
              <a
                class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm font-medium"
                href="/like/<%= post._id %>"
              >
                <%= post.likes.indexOf(user._id) === -1 ? "Like" : "Unlike" %>
              </a>

              <a
                class="bg-zinc-900/40 border border-zinc-700 hover:border-blue-500 hover:bg-zinc-900/60 px-4 py-2 rounded-lg text-sm font-medium"
                href="/edit/<%= post._id %>"
              >
                Edit
              </a>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="bg-zinc-800 p-6 rounded-2xl text-zinc-300">No posts yet.</div>
      <% } %>
    </div>
  </div>
</body>
</html>
