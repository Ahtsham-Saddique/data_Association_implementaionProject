<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-zinc-900 text-white min-h-screen">
    <div class="min-h-screen">
      <header class="border-b border-zinc-800/60">
        <div class="max-w-5xl mx-auto px-5 py-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl bg-blue-600/20 border border-blue-600/40 flex items-center justify-center">
              <span class="text-blue-200 font-bold">DA</span>
            </div>
            <div>
              <p class="text-sm text-zinc-400 leading-tight">Data Association</p>
              <p class="text-base font-semibold leading-tight">Social Profile</p>
            </div>
          </div>

          <nav class="flex items-center gap-2">
            <a
              href="/Profile"
              class="px-3 py-2 rounded-lg text-sm font-medium bg-zinc-800/60 hover:bg-zinc-800 border border-zinc-700/60"
              >Profile</a
            >
            <a
              href="/logout"
              class="px-3 py-2 rounded-lg text-sm font-medium bg-red-500/90 hover:bg-red-500"
              >Logout</a
            >
          </nav>
        </div>
      </header>

      <main class="max-w-5xl mx-auto px-5 py-8">
        <!-- Top Right Logout (kept in header; no extra UI needed) -->

        <!-- Profile Header -->
        <div class="flex items-center gap-4 mb-8">
          <a
            href="/profile/upload"
            class="relative inline-block rounded-full overflow-hidden w-20 h-20 ring-2 ring-zinc-700 hover:ring-blue-500 transition"
            title="Update profile picture"
          >
            <img
              class="w-full h-full object-cover"
              src="/images/uploads/<%= user.profilepic || 'default_image.png' %>"
              alt="Profile"
            />
            <div class="absolute inset-0 bg-black/0 hover:bg-black/30 transition flex items-center justify-center">
              <span class="opacity-0 hover:opacity-100 text-xs font-semibold">Update</span>
            </div>
          </a>

          <div>
            <h1 class="text-3xl font-semibold">
              <span class="font-light text-zinc-300">Hello</span>, <%= user.name %>
            </h1>
            <p class="text-zinc-400 mt-1">Create and manage your posts</p>

            <div class="mt-3">
              <a
                href="/profile/upload"
                class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm font-medium"
              >
                Update Profile Picture
              </a>
            </div>
            <p class="text-zinc-500 text-sm mt-2">Click your profile photo to update.</p>
          </div>
        </div>

        <!-- Create Post Form -->
        <div class="bg-zinc-800 border border-zinc-700/40 rounded-2xl p-5 mb-6">
          <form action="/post" method="post" class="space-y-4">
            <textarea
              name="content"
              placeholder="What's on your mind?"
              class="w-full p-3 rounded-xl bg-zinc-900/40 text-white outline-none border border-zinc-700 focus:border-blue-500"
              rows="4"
              required
            ></textarea>
            <button
              type="submit"
              class="bg-blue-600 hover:bg-blue-700 px-5 py-2 rounded-xl text-sm font-semibold"
            >
              Create Post
            </button>
          </form>
        </div>

        <!-- Posts Section -->
        <div class="mt-6">
          <div class="flex items-center justify-between gap-3 mb-4">
            <h2 class="text-xl font-semibold">Your Posts</h2>
            <span class="text-sm text-zinc-500"><%= user.posts?.length || 0 %> total</span>
          </div>

          <% if(user.posts && user.posts.length > 0) { %>
            <% user.posts.slice().reverse().forEach(post => { %>
              <div class="bg-zinc-800 border border-zinc-700/40 rounded-2xl p-5 mb-4">
                <p class="text-white break-words whitespace-pre-wrap"><%= post.content %></p>

                <div class="flex items-center justify-between gap-3 mt-4">
                  <p class="text-zinc-400 text-sm"><%= post.date ? post.date.toDateString() : '' %></p>

                  <div class="flex flex-wrap gap-3">
                    <a
                      class="px-4 py-2 rounded-lg text-sm font-medium <%= post.likes?.some(l => l.toString() === user._id.toString()) ? 'bg-blue-600 hover:bg-blue-700' : 'bg-zinc-900/40 border border-zinc-700 hover:border-blue-500 hover:bg-zinc-900/60' %>"
                      href="/like/<%= post._id %>"
                    >
                      <%= post.likes?.some(l => l.toString() === user._id.toString()) ? 'Unlike' : 'Like' %>
                    </a>

                    <a
                      class="bg-zinc-900/40 border border-zinc-700 hover:border-blue-500 hover:bg-zinc-900/60 px-4 py-2 rounded-lg text-sm font-medium"
                      href="/edit/<%= post._id %>"
                    >
                      Edit
                    </a>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="bg-zinc-800 border border-zinc-700/40 p-6 rounded-2xl text-zinc-300">
              No posts yet. Create your first post above.
            </div>
          <% } %>
        </div>
      </main>

      <footer class="max-w-5xl mx-auto px-5 pb-10">
        <p class="text-xs text-zinc-500">© <%= new Date().getFullYear() %> Data Association • Built with Express + EJS</p>
      </footer>
    </div>
  </body>
</html>

