<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-900 text-white min-h-screen p-10">

    <!-- Top Bar -->
    <div class="flex justify-end mb-6">
        <a href="/logout" class="bg-red-500 px-4 py-2 rounded-md text-sm">
            Logout
        </a>
    </div>

   
    <p class="text-zinc-400 mb-6">
        <Edit your post
    </p>

    <!-- Create Post Form -->
    <form action="/update/<%= post._id %>" method="post" class="mb-10">
        
        <textarea 
            name="content"
           
            class="w-full p-3 rounded-md bg-zinc-800 text-white outline-none mb-3"
            rows="4"
        ><%= post.content %></textarea>

        <button 
            type="submit"
            class="bg-yellow-500 px-5 py-2 rounded-md text-sm"
        >
            Update Post
        </button>

    </form>


   

</body>
</html>